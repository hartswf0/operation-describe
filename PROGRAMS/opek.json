] <model>.
      <output> still [requires
] <substrate-aware reading>.
      <human meaning> still [exceeds
] <model correlation>.
    </preserved_invariants>
  </scenario>

  <scenario id="C03_REJECT_ARTIFICIAL_SEMANTICS">
    <question>
