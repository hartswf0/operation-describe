<PROGRAM_THEORY name="OPERATIVE_EKPHRASIS_AFTER_AI">

<Initial_Interpretation>
  <paper> :=
    <argument-machine> [for transforming
] <ekphrasis>
    from <verbal representation of image>
    into <computational operation where text produces image>.

  <real_activity> :=
    <scholar> [studies
] how <multimodal AI> changes the relation between <text>, <image>, <meaning>, and <technical substrate>.

  <central_problem> :=
    <classical humanities concept> [meets
] <machine-learning system>
    and must [revise
] its own assumptions.

  <core_question> :=
    What happens to <ekphrasis> when <words> no longer merely [describe
] <images>,
