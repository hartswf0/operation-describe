<Change_Test>

  <scenario id="C01_VIDEO_GENERATION">
    <question>
      What changes if <image> becomes <video>?
    </question>

    <changed_entities>
      <Image> -> <MovingImage>
      <GeneratedImage> -> <GeneratedVideo>
      <Ekphrasis> -> <CinephrasticOperation>
      <spatial output> -> <temporal-spatial output>
    </changed_entities>

    <changed_operations>
      [generate
] must include <duration>, <motion>, <continuity>, <shot logic>, <frame coherence>.
      [interpret
] must include <editing>, <camera movement>, <sequence>, <temporal rhythm>.
    </changed_operations>

    <preserved_invariants>
      <text> still [produces
] <visual output>.
      <technical substrate> still [matters
].
      <artificial semantics> still [mediates
] <prompt-output relation>.
    </preserved_invariants>
  </scenario>

  <scenario id="C02_SOUND_GENERATION">
    <question>
      What changes if <image> becomes <sound>?
    </question>

    <changed_entities>
      <Image> -> <Sound>
      <VisualPoem> -> <SoundPoem>
      <GeneratedImage> -> <GeneratedAudio>
      <EmbeddingSpace> -> <audio-text representational space>
    </changed_entities>

    <changed_operations>
