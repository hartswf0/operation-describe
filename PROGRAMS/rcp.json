  8. <Program Text>

    <pseudo-program>

      DEFINE <Concept>:
        name
        concept_word
        task_family
        forbidden_reifications
        mastery_requirements

      DEFINE <Task>:
        operation_type
        prompt
        expected_operation
        variation_level
        evidence_weight

      DEFINE <Performance>:
        actor
        concept
        task
        result
        explanation
        observed_failure

      DEFINE <MasteryProfile>:
        actor
        concept
        operation_coverage
        mastery_state
        failure_modes
        missing_operations
        next_tests

      FUNCTION [evaluate_concept_possession
](actor, concept, performances):

        operation_coverage = [measure_operation_coverage
](performances)

        failure_modes = []

        IF [only_definition_successful
](performances):
          failure_modes.ADD(DEFINITIONISM)

        IF [word_used_but_operations_fail
](performances):
          failure_modes.ADD(WORD_CONCEPT_COLLAPSE)

        IF [fluent_explanation_but_transfer_fails
](performances):
          failure_modes.ADD(FALSE_FLUENCY)

        IF [single_task_success_claimed_as_mastery
](performances):
          failure_modes.ADD(SINGLE_TASK_OVERCLAIM)

        mastery_state = [assign_mastery_state
](operation_coverage, failure_modes)

        next_tests = [generate_next_tests
](concept, operation_coverage, failure_modes)

        RETURN <MasteryProfile>
          actor = actor
          concept = concept
          operation_coverage = operation_coverage
          mastery_state = mastery_state
          failure_modes = failure_modes
          missing_operations = [find_missing_operations
](operation_coverage)
          next_tests = next_tests

      FUNCTION [assign_mastery_state
](coverage, failures):

        IF coverage.total_success == 0:
          RETURN <not-yet-acquired>

        IF coverage.success_only_in("definition"):
          RETURN <definition-recitation>

        IF coverage.success_only_in("familiar_examples"):
          RETURN <example-bound-competence>

        IF coverage.success_in("rule_application") AND coverage.failure_in("explanation"):
          RETURN <rule-bound-competence>

        IF coverage.success_in("inference") AND coverage.success_in("application"):
          RETURN <inferential-competence>

        IF coverage.success_in("explanation") AND coverage.success_in("correction"):
          RETURN <explanatory-competence>

        IF coverage.success_in("transfer") AND coverage.success_in("detect_impossibility"):
          RETURN <transferable-mastery>

        RETURN <partial-mastery>

      FUNCTION [generate_next_tests
](concept, coverage, failures):

        IF DEFINITIONISM IN failures:
          RETURN <application-test + explanation-test>

        IF WORD_CONCEPT_COLLAPSE IN failures:
          RETURN <word-absent-operation-test>

        IF FALSE_FLUENCY IN failures:
          RETURN <edge-case + transfer-test + correction-test>

        IF SINGLE_TASK_OVERCLAIM IN failures:
          RETURN <task-family-expansion>

        RETURN <harder-variation-test>

    </pseudo-program>


