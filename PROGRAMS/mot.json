] "What did the author or agent mean?"

    <damage> :=
      <consequence> [disappears
]
      <trace-career> [disappears
]
      <public-meaning> [is-reduced-to
] <private-psychology>

    <correction> :=
      [read
] {inscription, detachment, circulation, consequence, world-projection
}
  </Failure>

  <Failure name="CONTEXT_PRISON">
    <symptom> :=
      <reading> [reduces
] <trace> to <origin-context>

    <damage> :=
      <importance> [is-collapsed-into
] <initial-relevance>

    <correction> :=
