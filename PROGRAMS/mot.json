<PROGRAM_THEORY name="THE_MODEL_OF_THE_TRACE" version="1.1">

<Core Thesis>
  <speech> [vanishes as
] <event>
  <writing> [rescues
] <the-said>
  <action> [vanishes as
] <event>
  <trace> [rescues
] <the-done>

  <meaning> [does-not-live-inside
] <intention>
  <meaning> [survives-as
] <inscribed-public-consequence>

  <human-science> [studies
] <meaningful-action-after-it-has-become-readable>

</Core Thesis>


1. <Initial Interpretation>

  <program theory problem> :=
    Build a conceptual machine that explains how <meaningful-action> becomes <interpretable> once it is detached from <agent>, <origin>, <situation>, and <intention>.

  <real-world activity> :=
    <interpreter> [reads
] <social-traces>
    <critic> [tests
] <competing-meanings>
    <historian> [reconstructs
] <action-afterlives>
    <media-theorist> [reads
] <digital-artifacts>
    <institutional-analyst> [exposes
] <bureaucratic-interpretations>

  <target phenomenon> :=
    <action> that has escaped its origin and now exists as:
      <text>
      <record>
      <archive>
      <file>
      <log>
      <dataset>
      <policy>
      <AI-output>
      <bureaucratic-category>
      <historical-event>
      <institutional-memory>

  <governing question> :=
    When <event> disappears, what remains readable?


