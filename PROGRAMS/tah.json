] <strong_claim>
    </invariant_03>

    <invariant_04>
      <interpretation> [must-have
] <rival_reading>
    </invariant_04>

    <invariant_05>
      <validation> [is-not
] <verification>
    </invariant_05>

    <invariant_06>
