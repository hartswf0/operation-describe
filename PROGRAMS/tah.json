] <old_trace>

  </morphisms>


  <state_machine>

    <state name="EVENT_PRESENT">
      <event> [is-live
]
      <meaning> [appears-bound-to
] <speaker_or_agent>
      transition: [vanish
] -> <EVENT_ABSENT>
    </state>

    <state name="EVENT_ABSENT">
      <event> [is-gone
]
      <trace> [may-remain
]
      transition:
        IF <trace> exists -> <TRACE_AVAILABLE>
        ELSE -> <INTERPRETATION_BLOCKED>
    </state>

    <state name="TRACE_AVAILABLE">
      <trace> [is-readable
]
      <interpreter> [can-begin
] <analysis>
      transition: [detach
] -> <MEANING_DETACHED>
    </state>

    <state name="MEANING_DETACHED">
      <meaning> [exceeds
] <intention>
      <meaning> [exceeds
] <situation>
      transition: [read
] -> <INTERPRETATION_STARTED>
    </state>

    <state name="INTERPRETATION_STARTED">
      <interpreter> [forms
] <guess>
      transition:
        IF <rival_reading> exists -> <INTERPRETATION_CONTESTED>
        ELSE -> <DOGMATIC_READING>
    </state>

    <state name="INTERPRETATION_CONTESTED">
      <guess> [faces
] <rival_reading>
      <evidence> [tests
] <claim>
      transition:
        IF <claim> survives <defeat_condition> -> <VALIDATED_READING>
        ELSE -> <DEFEATED_READING>
    </state>

    <state name="VALIDATED_READING">
      <interpretation> [is-probable-not-certain
]
      <world> [is-articulated
]
      <responsibility> [is-mapped
]
      transition: [reopen
] -> <HISTORICAL_REINTERPRETATION>
    </state>

    <state name="HISTORICAL_REINTERPRETATION">
      <new_reader> [encounters
] <old_trace>
      <new_context> [changes
] <meaning_pressure>
      transition: [contest
] -> <INTERPRETATION_CONTESTED>
    </state>

  </state_machine>


