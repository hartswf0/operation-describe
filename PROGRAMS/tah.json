<PROGRAM_THEORY id="TEXTUAL_ACTION_HERMENEUTICS" version="1.1">

  <core_problem>
    <event> disappears.
    <trace> remains.
    <trace> becomes readable.
    <reading> becomes contested.
    <contestation> demands validation.
    <validation> never becomes absolute certainty.

    Therefore:
      <human_sciences> [must-read
] <meaningful_action>
      not as <private_intention>
      and not as <raw_behavior>
      but as <inscribed_action>.

    Formula:
      <action> + <trace> + <social_time> + <rival_readings>
      [produces
]
      <validated_interpretation>
  </core_problem>


  <axioms>

    <axiom_01 name="EVENT_IS_NOT_MEANING">
      <event> [happens-once
]
      <meaning> [outlives
] <event>
      <interpretation> [begins-when
] <event> [is-no-longer-present
]
    </axiom_01>

    <axiom_02 name="WRITING_FIXES_THE_SAID">
      <writing> [does-not-fix
] <living_speech_event>
      <writing> [fixes
] <said>
      <said> := <discourse> [made-repeatable
]
    </axiom_02>

    <axiom_03 name="TEXT_ESCAPES_AUTHOR">
      <text> [has
] <author>
      <text> [is-not-governed-by
] <author_intention>
      <text> [develops
] <career_beyond_author>
    </axiom_03>

    <axiom_04 name="ACTION_ESCAPES_AGENT">
      <action> [has
] <agent>
      <action> [is-not-exhausted-by
] <agent_intention>
      <action> [develops
] <consequences_beyond_agent>
    </axiom_04>

    <axiom_05 name="TRACE_IS_SOCIAL_WRITING">
      <trace> := <action> [left-in
] <social_time>
      <record> := <trace> [made-durable
]
      <archive> := {<records>
} [available-for-reading
]
    </axiom_05>

    <axiom_06 name="INTERPRETATION_IS_DISCIPLINED_PLURALITY">
      <interpretation> [requires
] <guess>
      <guess> [requires
] <validation>
      <validation> [requires
] <rival_interpretation>
      <rival_interpretation> [may-defeat
] <guess>
    </axiom_06>

    <axiom_07 name="WORLD_NOT_CONTEXT">
      <situation> := <original_scene_of_event>
      <world> := <field_of_possible_meanings_opened_by_trace>
      <text_or_action> [does-not-merely-belong-to
] <situation>
      <text_or_action> [opens
] <world>
    </axiom_07>

    <axiom_08 name="NO_FINAL_RESCUE">
      <author> [cannot-rescue
] <text>
      <agent> [cannot-rescue
] <action>
      <designer> [cannot-rescue
] <technical_system>
      <meaning> [must-be-read-through
] <trace>
    </axiom_08>

  </axioms>


