  <morphisms>

    [vanish
]
      <event> [vanishes-into
] <past>

    [fix
]
      <writing> [fixes
] <said>

    [inscribe
]
      <action> [inscribes-itself-as
] <trace>

    [detach
]
      <meaning> [detaches-from
] <intention>
      <action> [detaches-from
] <agent>
      <text> [detaches-from
] <author>

    [sediment
]
