] <record>
    </invariant_10>

  </invariants>


  <interpretive_protocol>

    <step_01 name="LOCATE_EVENT">
      input: <case_material>
      operation: [identify
] <event>
      output: <event_description>
    </step_01>

    <step_02 name="LOCATE_TRACE">
      input: <event_description>
      operation: [find
] <trace>
      output: <trace_set>
      failure_if: <trace_set> [is-empty
]
    </step_02>

    <step_03 name="SEPARATE_EVENT_FROM_MEANING">
      input: <event_description>, <trace_set>
      operation: [distinguish
] <what_happened> [from
] <what_it_now_means>
      output: <meaning_gap>
    </step_03>

    <step_04 name="SEPARATE_INTENTION_FROM_TRACE">
      input: <agent_intention>, <trace_set>, <consequences>
      operation: [detach
] <meaning> [from
] <intention>
      output: <detachment_map>
    </step_04>

    <step_05 name="READ_TRACE_STRUCTURE">
      input: <trace_set>
      operation: [analyze
] {
        <propositional_content>,
        <illocutionary_force>,
        <rule_structure>,
        <institutional_context>,
        <technical_context>,
        <historical_context>
}
      output: <trace_profile>
    </step_05>

    <step_06 name="PROJECT_WORLD">
      input: <trace_profile>
      operation: [infer
] <world_opened>
      output: <world_projection>
    </step_06>

    <step_07 name="GENERATE_RIVAL_READINGS">
      input: <trace_profile>, <world_projection>
      operation: [produce
] {
        <intention_reading>,
        <consequence_reading>,
        <institutional_reading>,
        <technical_reading>,
        <political_reading>,
        <symbolic_reading>
}
      output: <rival_reading_set>
    </step_07>

    <step_08 name="VALIDATE">
      input: <rival_reading_set>, <trace_set>, <evidence>
      operation: [rank
] <interpretations> [by
] {
        <trace_fit>,
        <explanatory_power>,
        <consequence_coverage>,
        <defeat_resistance>,
        <world_clarity>,
        <responsibility_precision>
}
      output: <validated_interpretation>
    </step_08>

    <step_09 name="MAP_RESPONSIBILITY">
      input: <validated_interpretation>
      operation: [assign
] <responsibility>
      output: <responsibility_map>
    </step_09>

    <step_10 name="MARK_RESIDUAL_UNCERTAINTY">
      input: <validated_interpretation>, <missing_evidence>
      operation: [mark
] <uncertainty>
      output: <residual_uncertainty>
    </step_10>

  </interpretive_protocol>


