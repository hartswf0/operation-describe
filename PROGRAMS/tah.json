  <report_schema>

    <validated_interpretive_report> :=
      {
        <event>: "What happened?",

        <trace>: "What remains?",

        <inscription_mode>: "How did the event become durable?",

        <detachment>: "How does meaning exceed intention?",

        <world_opened>: "What possibilities, categories, roles, or futures does the trace project?",

        <rival_readings>: {
            <reading_01>,
            <reading_02>,
            <reading_03>,
            <reading_04>
    },

        <validation_logic>: "Why is one reading stronger than another?",

        <defeat_conditions>: "What would weaken the interpretation?",

        <responsibility_map>: "Who or what participates in the action's consequences?",

        <residual_uncertainty>: "What cannot be known from the available trace?",

        <method_warning>: "This is a validated interpretation, not absolute verification."
}

  </report_schema>


  <program_pseudocode>

    FUNCTION READ_TEXTUAL_ACTION(<case_material>):

      <event> := IDENTIFY_EVENT(<case_material>)

      IF <event> == null:
        RETURN FAILURE("No event. No interpretation.")

      <trace_set> := LOCATE_TRACES(<case_material>)

      IF <trace_set> == empty:
        RETURN WEAK_REPORT("No trace. Only speculative hypothesis possible.")

      <detachment_map> := MAP_DETACHMENT(
        <event>,
        <trace_set>,
        <known_intentions>,
        <observed_consequences>
      )

      <trace_profile> := READ_TRACE_STRUCTURE(
        <trace_set>,
        fields = {
          <propositional_content>,
          <force>,
          <rule_structure>,
          <institutional_context>,
          <technical_context>,
          <historical_context>
}
      )

      <world_projection> := PROJECT_WORLD(<trace_profile>)

      <rival_readings> := GENERATE_RIVAL_READINGS(
        <trace_profile>,
        <world_projection>,
        minimum = 3
      )

      FOR each <reading> in <rival_readings>:
        <reading.score> := VALIDATE(
          <reading>,
          against = {
            <trace_fit>,
            <evidence_strength>,
            <consequence_coverage>,
            <defeat_resistance>,
            <world_clarity>,
            <responsibility_precision>
}
        )

      <validated_reading> := SELECT_STRONGEST(<rival_readings>)

      <responsibility_map> := MAP_RESPONSIBILITY(
        <validated_reading>,
        <case_material>
      )

      <uncertainty> := MARK_UNCERTAINTY(
        <missing_traces>,
        <weak_evidence>,
        <unresolved_rivals>
      )

      RETURN <validated_interpretive_report> {
        event: <event>,
        trace: <trace_set>,
        detachment: <detachment_map>,
        world_opened: <world_projection>,
        rival_readings: <rival_readings>,
        validated_interpretation: <validated_reading>,
        responsibility_map: <responsibility_map>,
        residual_uncertainty: <uncertainty>
}

    END FUNCTION

  </program_pseudocode>


