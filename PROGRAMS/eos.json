      <file> thick.json </file>
      <relation> ELEPHANT_OS [operationalizes] thick programming compilation model </relation>
      <specific_use> Six personas map to {body, symbol, institution, interface, memory, scene} </specific_use>
    </dependency>

    <dependency name="OPERATIVE_EKPHRASIS">
      <file> opek.json </file>
      <relation> ELEPHANT_OS [introduces] fourth media regime (human-as-substrate) </relation>
      <specific_use> Proves operative ekphrasis is substrate-independent </specific_use>
    </dependency>

    <dependency name="DESCRIPTIVE_STRUGGLE_ENGINE">
      <file> dse.json </file>
      <relation> ELEPHANT_OS [stages] the descriptive struggle state machine </relation>
      <specific_use> Human drawing undergoes S0→S6 while machine output does not </specific_use>
    </dependency>

    <dependency name="MODEL_MEASURE_TRACTATUS">
      <file> mmt.json </file>
      <relation> ELEPHANT_OS [instantiates] Wittgensteinian operational depiction </relation>
      <specific_use> Drawing is a proposition, not a copy; tested by second-order AI guess </specific_use>
    </dependency>

    <dependency name="DESCRIPTIVE_REGIME_TRANSFER">
      <file> drtp-experimental-regimes.md </file>
      <relation> ELEPHANT_OS personas [can_be_replaced_by] experimental regimes </relation>
      <specific_use> ATC, Legal, Sports Radio, ISO regimes for falsifiability audits </specific_use>
    </dependency>
  </CROSS_REFERENCES>


  <IMPLEMENTATION>
    <file> elephant-os.html </file>
    <API> OpenAI GPT-4o (vision) </API>
    <auth> localStorage key: elephant_api_key </auth>
    <persistence>
      localStorage keys:
        elephant_score,
        elephant_frame,
        elephant_frames,
        elephant_archive
    </persistence>
    <prompt_fracture>
      PROMPT_FRACTURE constant enforces six persona triads.
      Critical rule: never say the name of the object.
    </prompt_fracture>
    <second_order>
      PROMPT_SECOND_ORDER: identify object from sketch only.
      Max tokens: 32. Blunt, one-word response.
    </second_order>
    <echolocation>
      Drawing is sonified via Web Audio API.
      Pen position maps to frequency, speed maps to gain.
      Audio feedback provides non-visual spatial orientation.
    </echolocation>
  </IMPLEMENTATION>

</PROGRAM_THEORY>
