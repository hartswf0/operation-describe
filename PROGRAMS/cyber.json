  <Failure Description>

    <failure name="ToolReduction">
      <symptom>
        <AIApparatus> [is_called
] <Tool>
      </symptom>
      <damage>
        <FeedbackLoop>, <HiddenCut>, <DistributedAgency>, and <WorldMakingEffect> [disappear
].
      </damage>
      <response>
        [Reclassify
] <AIApparatus> as <AgentialCyberneticMedium>.
      </response>
    </failure>

    <failure name="AuthorInflation">
      <symptom>
        <AIApparatus> [is_called
] <Author>
      </symptom>
      <damage>
        <Dataset>, <Labor>, <Interface>, <Institution>, <User>, and <CulturalMemory> [disappear
].
      </damage>
      <response>
        [Trace
] <DistributedAgency> across <HumanMachineWorldCircuit>.
      </response>
    </failure>

    <failure name="MirrorNaivety">
      <symptom>
        <AIApparatus> [is_called
] <Mirror>
      </symptom>
      <damage>
        <Generation>, <Ranking>, <Policy>, <Compression>, and <Modulation> [disappear
].
      </damage>
      <response>
        [Analyze
] <ApparatusProgram> and <PossibilitySpace>.
      </response>
    </failure>

    <failure name="BlackBoxFunctionaryMode">
      <symptom>
        <User> [mistakes
] <ApparatusDefaults> for <Freedom>.
      </symptom>
      <damage>
        <User> [becomes
] <FunctionaryOfProgram>.
      </damage>
      <response>
        [Expose
] <Defaults>, <Constraints>, <Provenance>, <Alternatives>, <FailureModes>.
      </response>
    </failure>

    <failure name="LegibilityCollapse">
      <symptom>
        <Model> [flattens
] <Context> into <Category>.
      </symptom>
      <damage>
        <Metis> [is_destroyed
].
      </damage>
      <response>
        [Preserve
] <LocalKnowledge>, <PluralDescriptions>, <SituatedJudgment>.
      </response>
    </failure>

    <failure name="ObjectiveFixation">
      <symptom>
        <System> [optimizes
] <SingleMetric>.
      </symptom>
      <damage>
        <SteppingStones>, <Novelty>, and <AdjacentPossible> [are_blocked
].
      </damage>
      <response>
        [Introduce
] <OpenEndedExploration>, <NoveltySearch>, <MultiCriteriaEvaluation>.
      </response>
    </failure>

    <failure name="IrresponsibleWorldModeling">
      <symptom>
        <WorldModel> [generates
] <WorldSurface> without <History>, <Relation>, <Constraint>, or <Context>.
      </symptom>
      <damage>
        <Simulation> [replaces
] <WorldComplexity>.
      </damage>
      <response>
        [Attach
] <Provenance>, <Uncertainty>, <ExclusionRecord>, <RelationalContext>.
      </response>
    </failure>

    <failure name="RelationalErasure">
      <symptom>
        <AgentSystem> [models
] <Person> as <IsolatedGoalSeekingIndividual>.
      </symptom>
      <damage>
        <Kinship>, <Obligation>, <Community>, <Territory>, and <NonHumanRelation> [are_erased
].
      </damage>
      <response>
        [Rebuild
] <AgentArchitecture> around <RelationalOntology>.
      </response>
    </failure>

  </Failure Description>


