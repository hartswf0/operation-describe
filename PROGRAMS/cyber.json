  <Program Text>

    <define>
      <AgentialCyberneticMedium> :=
        {
          <Model>,
          <Dataset>,
          <Interface>,
          <PolicyLayer>,
          <Institution>,
          <UserPractice>,
          <CulturalMemory>,
          <Infrastructure>,
          <FeedbackLoop>
}

      <WorldMakingCircuit> :=
        {
          <User>,
          <Prompt>,
          <AIApparatus>,
          <GeneratedSurface>,
          <Interpretation>,
          <Revision>,
          <Environment>
}

      <ResponsiblePractice> :=
        {
          <CutVisibility>,
          <Provenance>,
          <ChoiceAmplification>,
          <RelationalAdequacy>,
          <MetisPreservation>,
          <ApparatusLiteracy>,
          <WorldMakingAccountability>
}
    </define>

    <rule name="ReclassifyAI">
      IF <AIApparatus> [changes
] <ConditionsOfImagination>
      THEN <AIApparatus> [is
] <AgentialCyberneticMedium>
      NOT <MereTool>
    </rule>

    <rule name="EveryOutputHasCut">
      IF <Output> [appears
]
      THEN <AgentialCut> [has_occurred
]
      AND <ExcludedPossibilities> [exist
]
    </rule>

    <rule name="FeedbackAltersAgency">
      IF <User> [receives
] <Output>
      THEN <Output> [perturbs
] <UserImagination>
      AND <User> [revises
] <Prompt>
      AND <Circuit> [changes
] <FutureWorldSurface>
    </rule>

    <rule name="BlackBoxProducesFunctionary">
      IF <Apparatus> [hides
] <Program>
      AND <User> [accepts
] <Defaults>
      THEN <User> [becomes
] <Functionary>
    </rule>

    <rule name="LiteracyRequiresVisibility">
      IF <Interface> [reveals
] { <Cuts>, <Constraints>, <Alternatives>, <Provenance>, <Uncertainty>
}
      THEN <User> [can_play_against
] <ApparatusProgram>
    </rule>

    <rule name="FreedomRequiresVariety">
      IF <System> [has
] <RequisiteVariety>
      THEN <System> [can_support
] <Freedom>
      ELSE <System> [collapses_into
] <Control>
    </rule>

    <rule name="MetisProtection">
      IF <Model> [flattens
] <LocalKnowledge>
      THEN <ResponsiblePractice> [must_restore
] { <Context>, <Plurality>, <SituatedJudgment>
}
    </rule>

    <rule name="RelationalAI">
      IF <Agent> [is_modeled_as
] <IsolatedIndividual>
      THEN <RelationalDimensions> [are_at_risk
]

      IF <Agent> [is_modeled_through
] { <Kinship>, <Protocol>, <Community>, <Territory>, <NonHumanRelation>
}
      THEN <AgentSystem> [supports
] <RelationalOntology>
    </rule>

    <rule name="EthicsOfMattering">
      IF <System> [brings_forth
] <World>
      THEN { <Designer>, <User>, <Institution>, <ModelProvider>
} [must_accept
] <ResponsibilityForCuts>
    </rule>

    <main_loop>
      WHILE <HumanAIInteraction> [continues
]:

        <User> [prompts
] <AIApparatus>

        <AIApparatus> [cuts
] <EntangledReality>
        <AIApparatus> [compresses
] <CulturalMemory>
        <AIApparatus> [predicts
] <ProbableContinuation>
        <AIApparatus> [generates
] <WorldSurface>

        <WorldSurface> [perturbs
] <UserImagination>
        <UserImagination> [revises
] <PromptOrPractice>

        IF <WorldSurface> [reinforces
] <ApparatusDefault>:
          <Circuit> [moves_toward
] <FunctionaryMode>

        IF <WorldSurface> [opens
] <UnanticipatedPossibility>:
          <Circuit> [moves_toward
] <ChoiceAmplified>

        IF <Interface> [hides
] <Cut>:
          <Responsibility> [is_obscured
]

        IF <Interface> [reveals
] <Cut>:
          <Responsibility> [can_be_accepted>

        <WorldMakingCircuit> [updates
    ] <CulturalReality>

      END WHILE
    </main_loop>

    <return>
      <AgentialCyberneticMediaTheory> :=
        <GenerativeAI> [participates_in
    ] <WorldMaking>
        through <MaterialDiscursiveCyberneticApparatuses>.

        <ResponsiblePractice> [requires
    ]
        <VisibleCuts>,
        <PreservedRelations>,
        <AmplifiedChoice>,
        <MetisProtection>,
        and <AccountabilityForWorldsBroughtForth>.
    </return>

  </Program Text>


  <Theory-Code Mapping>

    <types>
      <AgentialCyberneticMedium> := the replacement for <Tool>, <Author>, and <Mirror>.
      <WorldMakingCircuit> := the Batesonian unit of mind/action across human-machine-environment.
      <ResponsiblePractice> := the Baradian ethics of mattering operationalized as design requirements.
      <PossibilitySpace> := the Flusserian apparatus program translated into generative AI.
      <RequisiteVariety> := the Beerian condition for freedom and viability.
      <Metis> := the Scottian defense against flattening, legibility, and monoculture.
    </types>

    <functions>
      [cut
    ] := enacts <Boundary> and creates <Responsibility>.
      [compress
    ] := converts <World> into <ModelUsableRepresentation>.
      [predict
    ] := generates <ProbableContinuation>.
      [generate
    ] := surfaces <TechnicalImage>, <Text>, or <WorldSurface>.
      [perturb
    ] := changes <UserImagination>.
      [feedback
    ] := recursively modifies <Circuit>.
      [play-against-program
    ] := resists <FunctionaryMode>.
      [amplify-choice
    ] := satisfies <EthicalImperative>.
      [preserve-metis
    ] := resists <LegibilityCollapse>.
    </functions>

    <tests>
      <test name="NotMereTool">
        GIVEN <AIApparatus>
        WHEN <Output> [changes
    ] <UserImagination>
        THEN <AIApparatus> [must_be_classified_as
    ] <WorldMakingParticipant>
      </test>

      <test name="CutVisibility">
        GIVEN <GeneratedOutput>
        WHEN <CutSource> [is_hidden
    ]
        THEN <ResponsibilityScore> [decreases
    ]
      </test>

      <test name="ChoiceAmplification">
        GIVEN <HumanAIWorkflow>
        WHEN <System> [increases
    ] <MeaningfulOptions>
        THEN <EthicalStatus> [improves
    ]
      </test>

      <test name="MetisPreservation">
        GIVEN <LocalContext>
        WHEN <Model> [flattens
    ] <LocalContext> into <UniversalCategory>
        THEN <FailureMode> [equals
    ] <LegibilityCollapse>
      </test>

      <test name="FunctionaryRisk">
        GIVEN <User>
        WHEN <User> [only_selects
    ] <ApparatusDefaults>
        THEN <Mode> [equals
    ] <FunctionaryMode>
      </test>
    </tests>

  </Theory-Code Mapping>


  <Residual Human Theory>

    <code_cannot_capture>
      <LivedContext>
      <HistoricalWound>
      <CulturalPractice>
      <EmbodiedJudgment>
      <PoliticalConsequence>
      <AestheticNecessity>
      <SpiritualRelation>
      <MaterialSuffering>
    </code_cannot_capture>

    <maintainer_law number="1">
      The central operation is not [generate
    ].
      The central operation is [cut
    ].
    </maintainer_law>

    <maintainer_law number="2">
      Every <Output> is a trace of prior <Cuts>.
      Every <Cut> creates <Responsibility>.
    </maintainer_law>

    <maintainer_law number="3">
      Never let <AIOutput> appear as innocent surface.
      Always reconnect it to: { <Apparatus>, <Dataset>, <Interface>, <Policy>, <Labor>, <Feedback>, <Loss>, <Provenance>, <WorldMakingEffect>
    }.
    </maintainer_law>

    <maintainer_law number="4">
      The goal is not <HumanlikeAI>.
      The goal is <ResponsibleHumanMachineWorldCircuits>.
    </maintainer_law>

  </Residual Human Theory>

</ProgramTheory>