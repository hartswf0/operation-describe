CORE_PROBLEM :=
Given <artifact>,
discover:
  1. <what_machine_generates_it>
  2. <what_rules_bind_it>
  3. <what_archive_feeds_it>
  4. <what_permutations_it_allows>
  5. <what_possibilities_it_blocks>
  6. <what_ghosts_it_produces>
  7. <what_power_relations_it_hides_or_repeats>


PRIMARY_ENTITIES :=
{
  <artifact>:
    text | story | myth | folktale | novel | essay | prompt | AI_output | interface | dataset_trace,

  <symbolic_inventory>:
    finite_collection_of <roles>, <figures>, <objects>, <actions>, <prohibitions>, <genres>, <settings>, <rituals>,

  <narrative_machine>:
    rule_bound_system_that_converts <symbolic_inventory> into <possible_sequences>,

  <function>:
    repeatable_operation_defined_by_position_not_surface_identity,

  <constraint>:
    rule_that_makes_some_sequences_possible_and_other_sequences_impossible,

  <permutation>:
    recombination_of_inherited_elements_under_constraint,

  <archive>:
    sedimented_store_of_prior_forms_genres_citations_myths_institutions_styles_and_templates,

  <reader_position>:
    role_the_artifact_constructs_for_interpretation_participation_desire_or_control,

  <agency_network>:
    distributed_field_of_human_and_nonhuman_participants_in_generation,

  <ghost>:
    unresolved_remainder_of <desire>, <memory>, <history>, <affect>, <ideology>, <reader_projection>, <political_pressure>,

  <critical_intervention>:
    explanation_of_how <machine> and <ghost> co-produce meaning
}


