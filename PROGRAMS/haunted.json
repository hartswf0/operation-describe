CRITICAL_RULES :=
{
  RULE_01:
    Never analyze <meaning> without analyzing <operation>.

  RULE_02:
    Never analyze <operation> without analyzing <remainder>.

  RULE_03:
    Never describe <constraint> without naming what it enables and what it blocks.

  RULE_04:
    Never locate <authorship> in only one agent.

  RULE_05:
    Never treat <AI_output> as either magic or mere emptiness.

  RULE_06:
    Never let <ghost> become mystical alibi.

  RULE_07:
    Never let <machine> become reductionist prison.

  RULE_08:
    Every <critical_intervention> must name the relation:
      <machine> [produces
    ] <ghost>
      <ghost> [reveals_limits_of
    ] <machine>
}


