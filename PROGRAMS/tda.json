<CHANGE_TESTS>

  <change_test name="PURE_GEERTZ_CHAPTER">
    IF <AI_extension> [is_removed
]
    THEN:
      EXPAND <Ryle>, <Wittgenstein>, <Ricoeur>, <Weber>, <Goodenough>
      KEEP <public_meaning>, <inscription>, <ground_near_theory>, <case_based_generalization>
  </change_test>

  <change_test name="AI_MEDIA_METHODS_CHAPTER">
    IF <paper> [becomes
] <AI_media_methods_chapter>
    THEN:
      MAKE <prompt>, <interface>, <dataset>, <platform_gesture>, <AI_output> PRIMARY
      MAKE <wink> ANALOGICAL_ENGINE
      MAKE <sheep_raid> MODEL_OF_FRAME_COLLISION
      KEEP <trace_is_not_meaning>
  </change_test>

  <change_test name="MEDIA_ARCHAEOLOGY_VERSION">
    IF <paper> [becomes
] <media_archaeology_essay>
    THEN:
      MAP <field_note> TO <database>, <log>, <archive>, <protocol>, <screen_recording>
      KEEP <inscription_after_event>
  </change_test>

  <change_test name="POLITICAL_THEORY_VERSION">
    IF <paper> [becomes
] <political_theory_chapter>
    THEN:
      CENTER <authority_to_define_meaning>
      CENTER <colonial_law>, <platform_governance>, <classification_power>
      KEEP <symbolic_action_under_power>
  </change_test>

</CHANGE_TESTS>


<OUTPUT_SCHEMA>
  <thick_interpretation> :=
  {
    <thin_description>: "What visibly happened?",

    <possible_symbolic_actions>: "What might this action count as?",

    <public_codes>: "What shared codes make those meanings possible?",

    <actor_frames>: "How do different actors read the same event?",

    <institutional_forces>: "What authorities stabilize or punish interpretations?",

    <inscription_chain>: "How did the event become an account?",

    <case_diagnosis>: "What is happening here, specifically?",

    <larger_issue>: "What large theoretical problem becomes thinkable through this case?",

    <limits>: "What remains uncertain, contestable, or unexhausted?"
}
</OUTPUT_SCHEMA>


<SUCCESS_CONDITION>
  The paper succeeds IF:

  <reader> [understands
] <thick_description> AS <interpretive_inscription_after_event>

  AND

  <reader> [can_distinguish
]:
    <motion> FROM <action>
    <trace> FROM <meaning>
    <context> FROM <decoration>
    <case> FROM <microcosm>
    <coherence> FROM <validity>
    <symbolic_analysis> FROM <politics_erasure>

  AND

  <reader> [can_apply
] <Geertzian_method> TO:
    <wink>
    <sheep_raid>
    <field_note>
    <prompt>
    <interface>
    <dataset>
    <platform_gesture>
    <AI_output>

  AND

  <theory> [remains
] <answerable_to_case>.
</SUCCESS_CONDITION>


<FINAL_THEOREM>
  <thick_description> is not <more_detail>.

  <thick_description> is the disciplined interpretation of <public_action>
  after <the_event> has vanished,
  through the inscription of <social_discourse>,
  under the pressure of <code>, <power>, <history>, and <misunderstanding>.

  Therefore:

  <culture> is not the hidden program beneath action.

  <culture> is the contested public world
  in which action becomes legible.
</FINAL_THEOREM>

</PROGRAM_THEORY>