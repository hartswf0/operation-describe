<CONSTRAINTS>
  DO_NOT [reduce
] <culture> TO <behavior>
  DO_NOT [reduce
] <culture> TO <private_mental_rules>
  DO_NOT [inflate
] <culture> INTO <everything>
  DO_NOT [detach
] <symbolic_system> FROM <actual_life>
  DO_NOT [mistake
] <field_site> FOR <object_of_study>
  DO_NOT [mistake
] <small_case> FOR <miniature_world>
  DO_NOT [mistake
] <technical_log> FOR <social_meaning>
  DO_NOT [allow
] <theory> TO [float_above
] <case>
  DO_NOT [remove
] <power> FROM <meaning>
  DO_NOT [treat
] <interpretation> AS <anything_goes>
</CONSTRAINTS>


<MAIN_ENGINE>

  <thin_description_engine>
    INPUT:
      <visible_motion>

    OPERATION:
      <visible_motion> [records_as
] <behavior>

    OUTPUT:
      <thin_description>

    FAILURE:
      <thin_description> [cannot_distinguish
] <twitch> FROM <wink>
      <thin_description> [cannot_read
] <social_code>
      <thin_description> [cannot_explain
] <meaning>
  </thin_description_engine>


  <thick_description_engine>
    INPUT:
      <visible_motion>
      <public_code>
      <actor_frame>
      <social_context>
      <institutional_pressure>
      <history_of_use>

    OPERATION:
      <visible_motion> [is_read_through
] <public_code>
      <public_code> [makes
] <motion> [count_as
] <symbolic_action>
      <symbolic_action> [is_interpreted_within
] <social_context>
      <social_context> [is_pressured_by
] <power>
      <power> [stabilizes_or_disrupts
] <valid_meaning>

    OUTPUT:
      <thick_description>
  </thick_description_engine>


  <wink_machine>
    INPUT:
      <eyelid_contraction>

    RULES:
      IF <eyelid_contraction> [is_involuntary
]
        THEN OUTPUT <twitch>

      IF <eyelid_contraction> [uses
] <public_code>
      AND <actor> [intends
] <specific_signal>
      AND <recipient> [can_read
] <code>
        THEN OUTPUT <wink>

      IF <eyelid_contraction> [imitates
] <wink>
      AND <purpose> [is
] <ridicule>
        THEN OUTPUT <parody>

      IF <eyelid_contraction> [prepares
] <future_parody>
        THEN OUTPUT <rehearsal>

      IF <eyelid_contraction> [performs
] <false_signal>
      AND <goal> [is
] <mislead_observer>
        THEN OUTPUT <fake_wink>

    THEORETICAL_FORCE:
      <same_motion> [can_become
] <different_actions>
      BECAUSE <meaning> [depends_on
] <public_code>
  </wink_machine>


  <sheep_raid_machine>
    INPUT:
      <Cohen_story>
      <Jewish_trade_frame>
      <Berber_honor_frame>
      <French_colonial_frame>

    FRAME_MAP:
      <Jewish_trade_frame>:
        <sheep> [count_as
] <indemnity>
        <raid> [counts_as
] <legitimate_claim>
        <trade_pact> [authorizes
] <reparative_action>

      <Berber_honor_frame>:
        <sheep> [count_as
] <negotiated_responsibility>
        <raid> [counts_as
] <challenge_and_settlement>
        <honor> [requires
] <recognized_response>

      <French_colonial_frame>:
        <sheep> [count_as
] <illegal_disorder>
        <trade_pact> [counts_as
] <abolished_practice>
        <colonial_authority> [claims
] <right_to_define_law>

    COLLISION:
      <same_event> [is_read_by
] <multiple_frames>
      <multiple_frames> [produce
] <systematic_misunderstanding>
      <colonial_authority> [seizes
] <right_to_define_meaning>

    OUTPUT:
      <political_semiotics_of_colonial_transition>
  </sheep_raid_machine>


  <inscription_machine>
    INPUT:
      <vanishing_event>

    OPERATION:
      <event> [passes_into
] <memory>
      <memory> [passes_into
] <informant_account>
      <informant_account> [passes_into
] <field_note>
      <field_note> [passes_into
] <anthropological_text>
      <anthropological_text> [passes_into
] <consultable_record>

    OUTPUT:
      <inscribed_social_discourse>

    CLAIM:
      <ethnographer> [does_not_capture
] <event_itself>
      <ethnographer> [inscribes
] <said_of_event>
  </inscription_machine>


  <appraisal_machine>
    INPUT:
      <interpretation>

    TESTS:
      IF <interpretation> [only_has
] <formal_coherence>
        THEN MARK <weak>

      IF <interpretation> [clarifies
] <what_action_counts_as>
      AND <interpretation> [preserves
] <particularity>
      AND <interpretation> [identifies
] <public_codes>
      AND <interpretation> [traces
] <power>
      AND <interpretation> [sharpens
] <debate>
        THEN MARK <strong>

    OUTPUT:
      <appraised_interpretation>
  </appraisal_machine>


  <generalization_machine>
    INPUT:
      <small_case>

    WRONG_PATH:
      <small_case> [is_treated_as
] <microcosm>
      OUTPUT <fallacy>

    RIGHT_PATH:
      <small_case> [concentrates
] <dense_relations>
      <dense_relations> [make_visible
] <large_issue>
      <large_issue> [is_reached_by
] <generalizing_within_case>

    OUTPUT:
      <case_based_theoretical_force>
  </generalization_machine>


  <AI_media_extension_machine>
    INPUT:
      <prompt>
      <interface_action>
      <dataset_category>
      <platform_click>
      <AI_output>

    RULES:
      <prompt> [is_not
] <mere_text>
      <prompt> [may_count_as
] <command>
      <prompt> [may_count_as
] <ritual>
      <prompt> [may_count_as
] <test>
      <prompt> [may_count_as
] <performance>
      <prompt> [may_count_as
] <labor_instruction>
      <prompt> [may_count_as
] <policy_probe>

      <interface_action> [is_not
] <mere_input>
      <interface_action> [may_count_as
] <consent>
      <interface_action> [may_count_as
] <compliance>
      <interface_action> [may_count_as
] <resistance>
      <interface_action> [may_count_as
] <play>
      <interface_action> [may_count_as
] <attack>

      <dataset_category> [is_not
] <neutral_label>
      <dataset_category> [is
] <inscription_of_prior_social_order>

      <AI_output> [is_not
] <self_explaining_file>
      <AI_output> [may_count_as
] <art>
      <AI_output> [may_count_as
] <evidence>
      <AI_output> [may_count_as
] <prototype>
      <AI_output> [may_count_as
] <fraud>
      <AI_output> [may_count_as
] <memory_object>
      <AI_output> [may_count_as
] <commodity>

    REQUIRED_QUESTIONS: [ask
] "What does this trace count as?"[ask
] "For whom?"[ask
] "Under what code?"[ask
] "Inside what institution?"[ask
] "With what consequence?"[ask
] "Who can stabilize the official meaning?"[ask
] "Who is punished by the official meaning?"

    OUTPUT:
      <thick_description_of_AI_media>
  </AI_media_extension_machine>

</MAIN_ENGINE>


